---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import RelatedArticles from '../components/RelatedArticles.astro';
import FaqSection from '../components/FaqSection.astro';
import AuthorBox from '../components/AuthorBox.astro';
import TableOfContents from '../components/TableOfContents.astro';
import { cocons } from '../data/cocons';
import '../styles/global.css';

interface Faq {
  question: string;
  answer: string;
}

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description: string;
  slug: string;
  cocon: string;
  updated: Date;
  published?: Date;
  readingTime?: string;
  faq?: Faq[];
  headings?: Heading[];
}

const { title, description, slug, cocon, updated, published, readingTime, faq = [], headings = [] } = Astro.props;

const faqSchema =
  faq.length > 0
    ? {
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        mainEntity: faq.map((item) => ({
          '@type': 'Question',
          name: item.question,
          acceptedAnswer: { '@type': 'Answer', text: item.answer },
        })),
      }
    : null;

// Article + BreadcrumbList : renforce l'EEAT (auteur, dates) et le maillage
// perçu par les moteurs/IA (fil d'Ariane structuré), en plus du visuel déjà
// affiché en haut de page.
const articleUrl = new URL(`/${slug}/`, Astro.site).toString();
const coconMeta = cocons.find((c) => c.slug === cocon);
const coconTitle = coconMeta?.title ?? cocon;
const coconUrl = new URL(`/ressources/${cocon}/`, Astro.site).toString();

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: (published ?? updated).toISOString(),
  dateModified: updated.toISOString(),
  author: { '@type': 'Organization', name: 'Tempo' },
  publisher: { '@type': 'Organization', name: 'Tempo' },
  mainEntityOfPage: articleUrl,
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: new URL('/', Astro.site).toString() },
    { '@type': 'ListItem', position: 2, name: coconTitle, item: coconUrl },
    { '@type': 'ListItem', position: 3, name: title, item: articleUrl },
  ],
};

const formattedDate = updated.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });
---

<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Tempo</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={new URL(`/${slug}/`, Astro.site)} />
    <meta property="og:title" content={`${title} — Tempo`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="article" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:wght@500;600&family=Source+Sans+3:wght@400;600&family=Space+Grotesk:wght@600&display=swap"
      rel="stylesheet"
    />
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
  </head>
  <body>
    <Header />

    <main>
      <div class="bg-ink text-white pt-12 pb-10">
        <div class="max-w-3xl mx-auto px-6">
          <div class="text-sm text-white/60 mb-3">
            <a href="/" class="hover:text-terracotta">Accueil</a> / <a href={`/ressources/${cocon}/`} class="hover:text-terracotta">{coconTitle}</a> / {title}
          </div>
          <h1 class="text-3xl md:text-4xl text-white">{title}</h1>
          <div class="flex gap-3 text-sm text-white/60 mt-3">
            <span>Mis à jour le {formattedDate}</span>
            {readingTime && (
              <>
                <span>·</span>
                <span>{readingTime}</span>
              </>
            )}
          </div>
        </div>
      </div>

      <div class="bg-white pt-10 pb-4">
        <div class="max-w-3xl mx-auto px-6 prose-tempo">
          <TableOfContents headings={headings} />
          <slot />
          <FaqSection faq={faq} />
          <AuthorBox />
        </div>
      </div>
      {/*
        Sommaire placé APRÈS l'intro (avant le premier H2), pas tout en haut :
        Astro ne permet pas de découper le <slot/>, on déplace donc le nœud #toc
        côté client juste avant le premier h2. Script exécuté dès la fin du bloc
        contenu (le prose est déjà parsé) pour éviter tout saut visible.
      */}
      <script is:inline>
        (function () {
          var prose = document.querySelector('.prose-tempo');
          if (!prose) return;
          var toc = prose.querySelector('#toc');
          var firstH2 = prose.querySelector('h2');
          if (toc && firstH2) prose.insertBefore(toc, firstH2);
        })();
      </script>
    </main>

    <RelatedArticles cocon={cocon} currentSlug={slug} />

    <Footer />
  </body>
</html>
